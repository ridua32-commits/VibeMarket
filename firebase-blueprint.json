{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["buyer", "seller", "admin"] },
        "bio": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Listing": {
      "title": "Marketplace Listing",
      "description": "A digital asset for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["SaaS", "Landing Page", "Mobile App", "AI Tool"] },
        "techStack": { "type": "array", "items": { "type": "string" } },
        "fileUrl": { "type": "string" },
        "demoLink": { "type": "string" },
        "screenshots": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "pending", "active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sellerId", "title", "price", "category", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "Record of a purchase transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "listingId": { "type": "string" },
        "amount": { "type": "number" },
        "stripeSessionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "sellerId", "listingId", "amount", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer feedback on a listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "buyerId": { "type": "string" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["listingId", "buyerId", "rating"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "listings/{listingId}": {
      "schema": "Listing",
      "description": "Marketplace items"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Purchase records"
    },
    "listings/{listingId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific listing"
    }
  }
}
